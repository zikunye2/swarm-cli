  "description": "Multi-Agent Deliberation CLI - runs coding tasks across multiple AI CLI agents in parallel, then synthesizes conflicts for human decision",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "swarm": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
