{
  "name": "swarm-cli",
  "version": "0.1.0",
  "description": "Multi-Agent Deliberation CLI - runs coding tasks across multiple AI CLI agents in parallel, then synthesizes conflicts for human decision",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "swarm": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "npm run build:tests && node --test dist-tests/tests/*.test.js",
    "test:unit": "npm run build:tests && node --test dist-tests/tests/config.test.js dist-tests/tests/logging.test.js",
    "test:integration": "npm run build:tests && node --test dist-tests/tests/worktree.test.js",
    "build:tests": "tsc -p tsconfig.test.json",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "cli",
    "multi-agent",
    "claude",
    "gemini",
    "codex",
    "deliberation",
    "code-review"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourrepo/swarm-cli.git"
  },
  "bugs": {
    "url": "https://github.com/yourrepo/swarm-cli/issues"
  },
  "homepage": "https://github.com/yourrepo/swarm-cli#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/generative-ai": "^0.24.1",
    "ink": "^5.2.0",
    "ink-spinner": "^5.0.0",
    "openai": "^6.27.0",
    "react": "^18.3.1",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
